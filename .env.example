APP_PORT=8080
PORT=8080

# Use localhost quando rodar a API fora do Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_DB=payment_db

REDIS_HOST=localhost
REDIS_PORT=6379

IDEMPOTENCY_TTL=24h
IDEMPOTENCY_LOCK_TTL=30s

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=payment
RABBITMQ_PASSWORD=payment
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=payment.events
RABBITMQ_QUEUE=payment

# Dead Letter Queue: tentativas de processamento antes de mandar à <fila>.dlq
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY=2s

# Outbox relay (cmd/outbox)
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=100

# Webhook service (cmd/webhook)
WEBHOOK_QUEUE=webhook.payment
WEBHOOK_HTTP_TIMEOUT=5s

# Webhook retry (poller dentro do cmd/webhook)
WEBHOOK_RETRY_MAX_ATTEMPTS=5     # tentativas antes de marcar como exhausted
WEBHOOK_RETRY_BASE_DELAY=30s     # atraso base do backoff exponencial (30s, 1m, 2m, ...)
WEBHOOK_RETRY_POLL_INTERVAL=10s  # intervalo de varredura das entregas falhas
WEBHOOK_RETRY_BATCH_SIZE=100     # máx. de entregas reprocessadas por ciclo

# PSP mock (cmd/consumer) — latência simulada da autorização (0 = sem espera)
PSP_MOCK_LATENCY=0

# Notification service (cmd/notification)
NOTIFICATION_QUEUE=notification.payment
NOTIFICATION_CHANNEL=email        # email | sms | push (mock, apenas loga)

# Audit service (cmd/audit) — trilha imutável de todos os eventos payment.*
AUDIT_QUEUE=audit.payment

# Seeder defaults (cmd/seed)
SEED_COUNT=25
