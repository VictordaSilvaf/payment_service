APP_PORT=8080
PORT=8080

# Use localhost quando rodar a API fora do Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_DB=payment_db

REDIS_HOST=localhost
REDIS_PORT=6379

IDEMPOTENCY_TTL=24h
IDEMPOTENCY_LOCK_TTL=30s

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=payment
RABBITMQ_PASSWORD=payment
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=payment.events
RABBITMQ_QUEUE=payment

# Outbox relay (cmd/outbox)
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=100

# Webhook service (cmd/webhook)
WEBHOOK_QUEUE=webhook.payment
WEBHOOK_HTTP_TIMEOUT=5s

# Seeder defaults (cmd/seed)
SEED_COUNT=25
